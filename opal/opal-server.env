# OPAL Server — local development environment
#
# OPAL Server watches a Git repository for policy + data changes and pushes
# updates to OPAL Clients (and through them, to OPA) in near-real-time.
#
# Local-dev source: the `opal-policy-repo-init` service builds a clean Git
# repo at /opal/repo inside a docker named volume from the workspace's
# `policies/` tree. OPAL Server treats it as a normal local Git remote.
# Production deployments swap this URL for an actual remote Git provider.
#
# No secrets in this file. JWT signing keys for production OPAL deployments
# come from a secret store, not from this env file.

# Bind addresses
OPAL_SERVER_HOST=0.0.0.0
OPAL_SERVER_PORT=7002

# Policy source — the docker volume that opal-policy-repo-init populates.
# Use the file:// scheme so GitPython treats it as a remote, not as a path
# on the local filesystem to copy into a working tree.
OPAL_POLICY_REPO_URL=file:///opal/repo
OPAL_POLICY_REPO_MAIN_BRANCH=main
OPAL_POLICY_REPO_POLLING_INTERVAL=5

# Limit the source to the policies/ subtree so OPAL only ingests Rego/JSON.
OPAL_POLICY_REPO_MANIFEST=policies

# Data sources — none yet. Phase 2 will add a `data_sources_config.json`
# describing where the OPAL Client should pull `data.agents`,
# `data.resource_permissions`, etc. from.
OPAL_ALL_DATA_URL=http://opal-server:7002/policy-data
OPAL_DATA_CONFIG_SOURCES={"config":{"entries":[]}}

# Authentication is disabled for the local dev stack. Production deployments
# enable JWT-based client auth via OPAL_AUTH_PRIVATE_KEY / OPAL_AUTH_PUBLIC_KEY.
OPAL_AUTH_MASTER_TOKEN=
OPAL_BROADCAST_URI=

# Logging
OPAL_LOG_FORMAT_INCLUDE_PID=true
OPAL_LOG_LEVEL=INFO
