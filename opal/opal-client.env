# OPAL Client — local development environment
#
# OPAL Client subscribes to OPAL Server over a WebSocket (the "PubSub"
# channel) and applies policy + data updates to the local OPA instance via
# OPA's REST API.
#
# In Docker Compose, the client is a sidecar of OPA (same network namespace
# is not required — the client just needs to reach OPA over HTTP).

# OPAL Server endpoint (inside the compose network)
OPAL_SERVER_URL=http://opal-server:7002

# Local OPA endpoint that the client writes to
OPAL_POLICY_STORE_URL=http://opa:8181

# Authentication disabled for local dev (matches opal-server.env).
OPAL_CLIENT_TOKEN=

# Polling fallback for data updates if PubSub disconnects.
OPAL_POLL_INTERVAL=10

# Inline data — none for now. Phase 2 wires up the agent / capability data.
OPAL_INLINE_OPA_LOG_FORMAT=http

# Logging
OPAL_LOG_FORMAT_INCLUDE_PID=true
OPAL_LOG_LEVEL=INFO
